<!DOCTYPE html>
<html lang="sk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ErfolgBau × Modulario — Dotazník</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Gabarito:wght@400;500;600;700;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root {
  --dark: #1a1a1e;
  --dark2: #222225;
  --dark3: #2d2d32;
  --card: rgba(255,255,255,0.04);
  --card-border: rgba(255,255,255,0.08);
  --yellow: #EBB22D;
  --yellow-glow: rgba(235,178,45,0.25);
  --blue: #3BC4EF;
  --blue-glow: rgba(59,196,239,0.2);
  --green: #2AB67D;
  --green-glow: rgba(42,182,125,0.2);
  --text: #f0f0f0;
  --text-muted: #949494;
  --text-dim: #616163;
  --input-bg: rgba(255,255,255,0.06);
  --input-border: rgba(255,255,255,0.12);
  --input-focus: rgba(235,178,45,0.4);
  --radius: 12px;
  --radius-lg: 20px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--dark);
  color: var(--text);
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── CANVAS BACKGROUND ── */
#bg-canvas {
  position: fixed;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

/* ── LAYOUT ── */
.container {
  position: relative;
  z-index: 1;
  max-width: 860px;
  margin: 0 auto;
  padding: 0 24px 80px;
}

/* ── HERO ── */
.hero {
  position: relative;
  z-index: 1;
  text-align: center;
  padding: 80px 24px 60px;
  max-width: 860px;
  margin: 0 auto;
}

.logo-mark {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 36px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.1s forwards;
}

.logo-puzzles {
  width: 36px;
  height: 36px;
}

.logo-text {
  font-family: 'Gabarito', sans-serif;
  font-weight: 700;
  font-size: 18px;
  letter-spacing: 2px;
  color: var(--text);
}

.logo-by {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 1px;
  display: block;
  text-align: left;
  margin-top: -4px;
}

.hero-eyebrow {
  font-family: 'Gabarito', sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: var(--yellow);
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.2s forwards;
}

.hero-title {
  font-family: 'Gabarito', sans-serif;
  font-size: clamp(32px, 5vw, 56px);
  font-weight: 900;
  line-height: 1.1;
  margin-bottom: 20px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.3s forwards;
}

.hero-title span {
  background: linear-gradient(90deg, var(--yellow), var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-sub {
  font-size: 17px;
  color: var(--text-muted);
  line-height: 1.65;
  max-width: 560px;
  margin: 0 auto 40px;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.4s forwards;
}

.hero-meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 28px;
  flex-wrap: wrap;
  opacity: 0;
  animation: fadeUp 0.7s ease 0.5s forwards;
}

.hero-meta-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  color: var(--text-muted);
}

.hero-meta-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--yellow);
  flex-shrink: 0;
}

/* ── PROGRESS ── */
.progress-wrap {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(26,26,30,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--card-border);
  padding: 14px 24px;
  opacity: 0;
  animation: fadeIn 0.5s ease 1s forwards;
}

.progress-inner {
  max-width: 860px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 16px;
}

.progress-bar-bg {
  flex: 1;
  height: 3px;
  background: rgba(255,255,255,0.08);
  border-radius: 99px;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--yellow), var(--blue));
  border-radius: 99px;
  transition: width 0.4s ease;
  width: 0%;
}

.progress-label {
  font-size: 12px;
  color: var(--text-muted);
  white-space: nowrap;
  font-family: 'Gabarito', sans-serif;
  min-width: 90px;
  text-align: right;
}

.progress-sections {
  display: flex;
  gap: 6px;
}

.progress-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: rgba(255,255,255,0.15);
  transition: background 0.3s;
  cursor: pointer;
}
.progress-dot.active { background: var(--yellow); }
.progress-dot.done { background: var(--green); }

/* ── SECTION ── */
.section {
  margin-bottom: 12px;
  border-radius: var(--radius-lg);
  border: 1px solid var(--card-border);
  background: var(--card);
  overflow: hidden;
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}
.section.visible { opacity: 1; transform: translateY(0); }

.section-header {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 24px 28px;
  background: rgba(255,255,255,0.03);
  border-bottom: 1px solid var(--card-border);
  cursor: pointer;
  user-select: none;
  transition: background 0.2s;
}
.section-header:hover { background: rgba(255,255,255,0.05); }

.section-badge {
  font-family: 'Gabarito', sans-serif;
  font-weight: 900;
  font-size: 15px;
  width: 38px;
  height: 38px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: #fff;
}

.section-titles { flex: 1; }

.section-title {
  font-family: 'Gabarito', sans-serif;
  font-weight: 700;
  font-size: 17px;
  color: var(--text);
  margin-bottom: 2px;
}

.section-sub {
  font-size: 13px;
  color: var(--text-muted);
}

.section-chevron {
  color: var(--text-dim);
  transition: transform 0.3s;
  font-size: 18px;
}

.section-body {
  padding: 8px 0;
  display: none;
}
.section-body.open { display: block; }
.section-header.open .section-chevron { transform: rotate(180deg); }

/* ── QUESTION ── */
.q-wrap {
  padding: 22px 28px;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.q-wrap:last-child { border-bottom: none; }

.q-num {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 2px;
  color: var(--text-dim);
  font-family: 'Gabarito', sans-serif;
  margin-bottom: 8px;
  text-transform: uppercase;
}

.q-text {
  font-size: 15px;
  font-weight: 500;
  color: var(--text);
  line-height: 1.5;
  margin-bottom: 6px;
}

.q-hint {
  font-size: 13px;
  color: var(--text-dim);
  font-style: italic;
  margin-bottom: 14px;
  line-height: 1.5;
}

/* ── INPUTS ── */
textarea, input[type="text"], input[type="email"] {
  width: 100%;
  background: var(--input-bg);
  border: 1px solid var(--input-border);
  border-radius: var(--radius);
  color: var(--text);
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  padding: 12px 16px;
  resize: vertical;
  outline: none;
  transition: border-color 0.2s, box-shadow 0.2s;
  margin-top: 10px;
}

textarea { min-height: 80px; }

textarea:focus, input[type="text"]:focus, input[type="email"]:focus {
  border-color: var(--yellow);
  box-shadow: 0 0 0 3px var(--yellow-glow);
}

textarea::placeholder, input::placeholder { color: var(--text-dim); }

/* ── CHECKBOXES ── */
.checks-grid {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 12px;
}

.check-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 10px 14px;
  border: 1px solid var(--input-border);
  border-radius: 10px;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
  background: var(--input-bg);
}

.check-item:hover {
  background: rgba(235,178,45,0.06);
  border-color: rgba(235,178,45,0.25);
}

.check-item input[type="checkbox"] { display: none; }

.check-box {
  width: 18px;
  height: 18px;
  border: 2px solid var(--input-border);
  border-radius: 5px;
  flex-shrink: 0;
  margin-top: 1px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.15s, border-color 0.15s;
}

.check-item.checked .check-box {
  background: var(--yellow);
  border-color: var(--yellow);
}

.check-box-tick {
  display: none;
  width: 10px;
  height: 7px;
  border-left: 2px solid #fff;
  border-bottom: 2px solid #fff;
  transform: rotate(-45deg) translate(1px, -1px);
}
.check-item.checked .check-box-tick { display: block; }

.check-label {
  font-size: 14px;
  color: #c8c8ca;
  line-height: 1.45;
  flex: 1;
}
.check-item.checked .check-label { color: var(--text); }

/* ── SUB QUESTIONS ── */
.sub-q {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px dashed rgba(255,255,255,0.07);
}

.sub-q-label {
  font-size: 13px;
  color: var(--text-muted);
  margin-bottom: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.sub-q-label::before {
  content: '↳';
  color: var(--yellow);
  font-size: 14px;
}

/* ── EMAIL FIELD ── */
.email-section {
  background: linear-gradient(135deg, rgba(235,178,45,0.08), rgba(59,196,239,0.05));
  border: 1px solid rgba(235,178,45,0.2);
  border-radius: var(--radius-lg);
  padding: 32px 28px;
  margin-bottom: 24px;
  text-align: center;
}

.email-section h3 {
  font-family: 'Gabarito', sans-serif;
  font-size: 20px;
  font-weight: 700;
  margin-bottom: 8px;
}

.email-section p {
  font-size: 14px;
  color: var(--text-muted);
  margin-bottom: 20px;
  line-height: 1.55;
}

.email-input-wrap {
  max-width: 420px;
  margin: 0 auto;
}

.email-input-wrap input[type="email"] {
  text-align: center;
  font-size: 15px;
  padding: 14px 20px;
  border-radius: 99px;
}

/* ── SUBMIT ── */
.submit-wrap {
  text-align: center;
  padding-top: 16px;
}

.btn-submit {
  font-family: 'Gabarito', sans-serif;
  font-weight: 700;
  font-size: 16px;
  letter-spacing: 0.5px;
  background: var(--yellow);
  color: #1a1a1e;
  border: none;
  border-radius: 99px;
  padding: 16px 52px;
  cursor: pointer;
  transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  box-shadow: 0 0 32px var(--yellow-glow);
  position: relative;
  overflow: hidden;
}

.btn-submit:hover {
  background: #f0bb38;
  transform: translateY(-2px);
  box-shadow: 0 4px 40px rgba(235,178,45,0.45);
}

.btn-submit:active { transform: translateY(0); }

.btn-submit .btn-loading {
  display: none;
  width: 18px;
  height: 18px;
  border: 2px solid rgba(0,0,0,0.2);
  border-top-color: #1a1a1e;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
  margin: 0 auto;
}
.btn-submit.loading span { display: none; }
.btn-submit.loading .btn-loading { display: block; }

.submit-note {
  font-size: 12px;
  color: var(--text-dim);
  margin-top: 12px;
}

/* ── SUCCESS ── */
.success-screen {
  display: none;
  text-align: center;
  padding: 80px 24px;
  max-width: 500px;
  margin: 0 auto;
}

.success-icon {
  width: 72px;
  height: 72px;
  background: linear-gradient(135deg, var(--yellow), var(--green));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24px;
  font-size: 32px;
  animation: popIn 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

@keyframes popIn {
  from { transform: scale(0); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.success-screen h2 {
  font-family: 'Gabarito', sans-serif;
  font-size: 28px;
  font-weight: 800;
  margin-bottom: 12px;
}

.success-screen p {
  font-size: 15px;
  color: var(--text-muted);
  line-height: 1.6;
}

/* ── SECTION COLORS ── */
.badge-a { background: linear-gradient(135deg, #3BC4EF, #2296b5); }
.badge-b { background: linear-gradient(135deg, #2AB67D, #1e8a5e); }
.badge-c { background: linear-gradient(135deg, #EBB22D, #c8931a); }
.badge-d { background: linear-gradient(135deg, #9B59B6, #7d3fa1); }
.badge-e { background: linear-gradient(135deg, #E74C3C, #c0392b); }
.badge-f { background: linear-gradient(135deg, #3BC4EF, #2296b5); }
.badge-g { background: linear-gradient(135deg, #2AB67D, #1e8a5e); }
.badge-h { background: linear-gradient(135deg, #EBB22D, #c8931a); }
.badge-i { background: linear-gradient(135deg, #9B59B6, #7d3fa1); }
.badge-j { background: linear-gradient(135deg, #E74C3C, #c0392b); }

/* ── ANIMATIONS ── */
@keyframes fadeUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}
@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ── DIVIDER ── */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--card-border), transparent);
  margin: 4px 0;
}

/* ── RESPONSIVE ── */
@media (max-width: 600px) {
  .section-header { padding: 18px 20px; }
  .q-wrap { padding: 18px 20px; }
  .hero { padding: 60px 20px 40px; }
  .email-section { padding: 24px 20px; }
  .hero-meta { gap: 16px; }
}
</style>
</head>
<body>

<canvas id="bg-canvas"></canvas>

<!-- HERO -->
<div class="hero">
  <div class="logo-mark">
    <svg class="logo-puzzles" viewBox="0 0 36 36" fill="none">
      <path d="M4 4h11v4.5a2.5 2.5 0 0 0 5 0V4h11v11h-4.5a2.5 2.5 0 0 0 0 5H31v11H20v-4.5a2.5 2.5 0 0 0-5 0V31H4V20h4.5a2.5 2.5 0 0 0 0-5H4z" fill="none"/>
      <path d="M4 4h11v4.5a2.5 2.5 0 0 0 5 0V4h7v7h-4.5a2.5 2.5 0 0 0 0 5H26v7H15v-4.5a2.5 2.5 0 0 0-5 0V26H4V15h4.5a2.5 2.5 0 0 0 0-5H4z" fill="#3BC4EF" opacity="0.9"/>
      <path d="M26 11h5v15h-4.5a2.5 2.5 0 0 0 0 5H31v5H20v-4.5a2.5 2.5 0 0 0-5 0V31h-4V20h7v-4.5a2.5 2.5 0 0 0-5 0V11h13z" fill="#2AB67D" opacity="0.85"/>
      <path d="M4 26h11v5H4z" fill="#EBB22D" opacity="0.9"/>
    </svg>
    <div>
      <span class="logo-text">MODULARIO</span>
      <span class="logo-by">by amcef</span>
    </div>
  </div>

  <div class="hero-eyebrow">ErfolgBau × Modulario</div>
  <h1 class="hero-title">Ako dnes funguje<br><span>Vaša firma?</span></h1>
  <p class="hero-sub">Dotazník pre prípravu analýzy.</p>

  <div class="hero-meta">
    <div class="hero-meta-item"><div class="hero-meta-dot"></div>10 sekcií · 39 otázok</div>
    <div class="hero-meta-item"><div class="hero-meta-dot" style="background:var(--blue)"></div>~15 minút</div>
    <div class="hero-meta-item"><div class="hero-meta-dot" style="background:var(--green)"></div>Odpovedajte len čo viete</div>
  </div>
</div>

<!-- STICKY PROGRESS -->
<div class="progress-wrap" id="progressWrap">
  <div class="progress-inner">
    <div class="progress-sections" id="progressDots"></div>
    <div class="progress-bar-bg">
      <div class="progress-bar-fill" id="progressFill"></div>
    </div>
    <div class="progress-label" id="progressLabel">0 / 39</div>
  </div>
</div>

<!-- MAIN FORM -->
<div class="container">
<form id="mainForm" action="https://formspree.io/f/mbdzbowp" method="POST">

<!-- Hidden field to label the submission -->
<input type="hidden" name="_subject" value="ErfolgBau — Dotazník pred analýzou">

<!-- ══════════════════════════════════════ A ══ -->
<div class="section" data-section="0">
  <div class="section-header" onclick="toggleSection(this)">
    <div class="section-badge badge-a">A</div>
    <div class="section-titles">
      <div class="section-title">Firma a ľudia</div>
      <div class="section-sub">Základné info o štruktúre Vašej firmy</div>
    </div>
    <div class="section-chevron">⌄</div>
  </div>
  <div class="section-body open">

    <div class="q-wrap">
      <div class="q-num">Otázka 1</div>
      <div class="q-text">Koľko pracovníkov (živnostníkov / zamestnancov) vysiela Vaša firma aktuálne do zahraničia? Koľko plánujete mať o rok?</div>
      <div class="q-hint">Napr. dnes 4, plán do roka 15.</div>
      <textarea name="A1_pocet_pracovnikov" placeholder="Vaša odpoveď..."></textarea>
    </div>

    <div class="q-wrap">
      <div class="q-num">Otázka 2</div>
      <div class="q-text">Kto bude so systémom pracovať? Označte všetky roly:</div>
      <div class="checks-grid">
        <label class="check-item"><input type="checkbox" name="A2_roly[]" value="Robotník — zapisuje vlastné hodiny cez mobil / PC"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Robotník — zapisuje vlastné hodiny cez mobil / PC</span></label>
        <label class="check-item"><input type="checkbox" name="A2_roly[]" value="Majster / party vedúci — kontroluje hodiny partie"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Majster / party vedúci — kontroluje hodiny partie</span></label>
        <label class="check-item"><input type="checkbox" name="A2_roly[]" value="Admin (ja) — schvaľujem, generujem faktúry, vidím všetko"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Admin (ja) — schvaľujem, generujem faktúry, vidím všetko</span></label>
        <label class="check-item"><input type="checkbox" name="A2_roly[]" value="Účtovníčka — dostáva len výstupy (faktúry, reporty)"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Účtovníčka — dostáva len výstupy (faktúry, reporty)</span></label>
      </div>
    </div>

    <div class="q-wrap">
      <div class="q-num">Otázka 3</div>
      <div class="q-text">Kto dnes vykonáva administratívu (hodiny, faktúry, výplaty)? Zostane táto osoba, alebo to má systém prevziať úplne?</div>
      <textarea name="A3_administrativa" placeholder="Vaša odpoveď..."></textarea>
    </div>

    <div class="q-wrap">
      <div class="q-num">Otázka 4</div>
      <div class="q-text">Máte alebo plánujete mať vlastných zamestnancov (nie živnostníkov)?</div>
      <div class="checks-grid">
        <label class="check-item"><input type="checkbox" name="A4_zamestnanci[]" value="Nie, iba živnostníci"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Nie, iba živnostníci</span></label>
        <label class="check-item"><input type="checkbox" name="A4_zamestnanci[]" value="Áno, mám aj zamestnancov"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Áno, mám aj zamestnancov</span></label>
        <label class="check-item"><input type="checkbox" name="A4_zamestnanci[]" value="Plánujem zamestnancov v budúcnosti"><div class="check-box"><div class="check-box-tick"></div></div><span class="check-label">Plánujem zamestnancov v budúcnosti</span></label>
      </div>
      <div class="sub-q">
        <div class="sub-q-label">Ak áno — líši sa spôsob evidencie od živnostníkov?</div>
        <textarea name="A4_zamestnanci_doplnok" placeholder="Doplňte..."></textarea>
      </div>
    </div>

  </div>
</div>

<!-- ══════════════════════════════════════ B ══ -->
<div class="section" data-section="1">
  <div class="section-header" onclick="toggleSection(this)">
    <div class="section-badge badge-b">B</div>
