<script>
// ── CANVAS BACKGROUND ──────────────────────────────────────────────────────
const canvas = document.getElementById('bg-canvas');
const ctx = canvas.getContext('2d');
let W, H, particles = [], lines = [];

function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}

function initParticles() {
  particles = [];
  const count = Math.floor((W * H) / 18000);
  for (let i = 0; i < count; i++) {
    particles.push({
      x: Math.random() * W,
      y: Math.random() * H,
      vx: (Math.random() - 0.5) * 0.3,
      vy: (Math.random() - 0.5) * 0.3,
      r: Math.random() * 1.5 + 0.3,
      alpha: Math.random() * 0.4 + 0.1
    });
  }
}

function drawBg() {
  ctx.clearRect(0, 0, W, H);

  // Gradient mesh background
  const grad = ctx.createRadialGradient(W * 0.3, H * 0.2, 0, W * 0.3, H * 0.2, W * 0.7);
  grad.addColorStop(0, 'rgba(59,196,239,0.04)');
  grad.addColorStop(0.5, 'rgba(235,178,45,0.02)');
  grad.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grad;
  ctx.fillRect(0, 0, W, H);

  const grad2 = ctx.createRadialGradient(W * 0.8, H * 0.7, 0, W * 0.8, H * 0.7, W * 0.6);
  grad2.addColorStop(0, 'rgba(42,182,125,0.04)');
  grad2.addColorStop(1, 'rgba(0,0,0,0)');
  ctx.fillStyle = grad2;
  ctx.fillRect(0, 0, W, H);

  // Particles
  particles.forEach((p, i) => {
    p.x += p.vx;
    p.y += p.vy;
    if (p.x < 0) p.x = W;
    if (p.x > W) p.x = 0;
    if (p.y < 0) p.y = H;
    if (p.y > H) p.y = 0;

    ctx.beginPath();
    ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(235,178,45,${p.alpha})`;
    ctx.fill();

    // Connect nearby
    for (let j = i + 1; j < particles.length; j++) {
      const dx = particles[j].x - p.x;
      const dy = particles[j].y - p.y;
      const dist = Math.sqrt(dx * dx + dy * dy);
      if (dist < 120) {
        ctx.beginPath();
        ctx.moveTo(p.x, p.y);
        ctx.lineTo(particles[j].x, particles[j].y);
        ctx.strokeStyle = `rgba(59,196,239,${0.06 * (1 - dist / 120)})`;
        ctx.lineWidth = 0.5;
        ctx.stroke();
      }
    }
  });

  requestAnimationFrame(drawBg);
}

resize();
initParticles();
drawBg();
window.addEventListener('resize', () => { resize(); initParticles(); });

// ── CHECKBOXES ────────────────────────────────────────────────────────────
document.querySelectorAll('.check-item').forEach(item => {
  item.addEventListener('click', () => {
    const cb = item.querySelector('input[type="checkbox"]');
    cb.checked = !cb.checked;
    item.classList.toggle('checked', cb.checked);
    updateProgress();
  });
});

// ── SECTION TOGGLE ────────────────────────────────────────────────────────
function toggleSection(header) {
  const body = header.nextElementSibling;
  const isOpen = body.classList.contains('open');
  body.classList.toggle('open', !isOpen);
  header.classList.toggle('open', !isOpen);
}

// Open first section by default - already done in HTML
document.querySelector('.section-header').classList.add('open');

// ── SCROLL REVEAL ─────────────────────────────────────────────────────────
const observer = new IntersectionObserver((entries) => {
  entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold: 0.05, rootMargin: '0px 0px -40px 0px' });

document.querySelectorAll('.section').forEach(s => observer.observe(s));

// ── PROGRESS ──────────────────────────────────────────────────────────────
const TOTAL = 39;
const dots = document.getElementById('progressDots');
const fill = document.getElementById('progressFill');
const label = document.getElementById('progressLabel');

// Create dots
for (let i = 0; i < 10; i++) {
  const d = document.createElement('div');
  d.className = 'progress-dot';
  d.dataset.idx = i;
  d.title = ['A','B','C','D','E','F','G','H','I','J'][i];
  d.addEventListener('click', () => {
    const section = document.querySelectorAll('.section')[i];
    section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    const body = section.querySelector('.section-body');
    const header = section.querySelector('.section-header');
    if (!body.classList.contains('open')) {
      body.classList.add('open');
      header.classList.add('open');
    }
  });
  dots.appendChild(d);
}

function updateProgress() {
  // Count filled fields
  let filled = 0;
  document.querySelectorAll('textarea').forEach(t => { if (t.value.trim()) filled++; });
  document.querySelectorAll('input[type="checkbox"]:checked').forEach(() => filled++);
  const emailFilled = document.querySelector('input[type="email"]').value.trim() ? 1 : 0;

  const pct = Math.min(100, Math.round((filled / TOTAL) * 100));
  fill.style.width = pct + '%';
  label.textContent = pct + '% hotovo';

  // Update dots per section
  const sections = document.querySelectorAll('.section');
  sections.forEach((sec, i) => {
    const dot = dots.children[i];
    const inputs = sec.querySelectorAll('textarea, input[type="checkbox"]:checked');
    const hasAny = [...sec.querySelectorAll('textarea')].some(t => t.value.trim()) ||
                   [...sec.querySelectorAll('input[type="checkbox"]:checked')].length > 0;
    dot.className = 'progress-dot' + (hasAny ? ' done' : '');
  });
}

document.querySelectorAll('textarea, input[type="email"]').forEach(el => {
  el.addEventListener('input', updateProgress);
});

// ── FORMSPREE SUBMIT ──────────────────────────────────────────────────────
const form = document.getElementById('mainForm');
const submitBtn = document.getElementById('submitBtn');
const successScreen = document.getElementById('successScreen');

form.addEventListener('submit', async (e) => {
  e.preventDefault();
  submitBtn.classList.add('loading');

  const data = new FormData(form);

  try {
    const res = await fetch(form.action, {
      method: 'POST',
      body: data,
      headers: { 'Accept': 'application/json' }
    });

    if (res.ok) {
      form.style.display = 'none';
      successScreen.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
      document.querySelector('.hero').style.display = 'none';
      document.querySelector('.progress-wrap').style.display = 'none';
    } else {
      alert('Nastala chyba pri odosielaní. Skúste prosím znova alebo nás kontaktujte emailom.');
      submitBtn.classList.remove('loading');
    }
  } catch (err) {
    alert('Nastala chyba pri odosielaní. Skontrolujte internetové pripojenie.');
    submitBtn.classList.remove('loading');
  }
});
</script>
</body>
</html>
